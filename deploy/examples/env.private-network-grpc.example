# clockify-mcp: private-network-grpc profile
# -----------------------------------------------------------------------------
# gRPC transport for callers on a private network. Requires a build
# with -tags=grpc: the default binary does not include the gRPC
# transport (ADR 0001 — stdlib-only default). mTLS is the default
# auth mode under this profile because gRPC services sitting on
# private networks typically authenticate the caller via client
# certificates issued by an internal CA.
#
# Apply via:
#   source env.private-network-grpc.example && clockify-mcp
# Or equivalently:
#   clockify-mcp --profile=private-network-grpc
#
# See docs/deploy/profile-private-network-grpc.md for the profile rationale.

MCP_PROFILE=private-network-grpc

# REQUIRED: Your Clockify API key. Used by every tool call.
CLOCKIFY_API_KEY=your-api-key

# REQUIRED for mTLS: paths to server cert / key and the CA bundle
# that issued the expected client certs.
MCP_GRPC_TLS_CERT=/etc/clockify-mcp/tls/server.crt
MCP_GRPC_TLS_KEY=/etc/clockify-mcp/tls/server.key
MCP_MTLS_CA_CERT_PATH=/etc/clockify-mcp/tls/client-ca.pem

# REQUIRED: Postgres control plane. A single-process gRPC deployment
# could technically use a file backend, but production gRPC tends
# to run HA so this profile pins postgres to keep deployments
# upgrade-ready.
MCP_CONTROL_PLANE_DSN=postgres://user:pass@db-host:5432/clockify_mcp?sslmode=verify-full

# Optional: override the default bind.
# MCP_GRPC_BIND=:9090

# Optional: mTLS tenant extraction. By default tenant is read from
# the Subject/SAN of the client cert. Override if your CA encodes it
# differently.
# MCP_MTLS_TENANT_HEADER=X-Tenant-ID

# Optional: metrics on a separate port so mTLS doesn't gate Prometheus.
# MCP_METRICS_BIND=:9091
# MCP_METRICS_AUTH_MODE=none
