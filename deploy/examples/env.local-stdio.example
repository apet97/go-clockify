# clockify-mcp: local-stdio profile
# -----------------------------------------------------------------------------
# Single-user local stdio server. Intended for IDE / CLI use: spawn the
# binary with MCP_PROFILE=local-stdio (or the --profile=local-stdio flag)
# and talk to it over stdin/stdout. No control plane, no auth, no HTTP
# listener. Policy is pinned to safe_core so a misbehaving LLM cannot
# reach admin-level tools by default.
#
# Apply via:
#   source env.local-stdio.example && clockify-mcp
# Or equivalently:
#   clockify-mcp --profile=local-stdio
#
# See docs/deploy/profile-local-stdio.md for the profile rationale.

MCP_PROFILE=local-stdio

# REQUIRED: Your Clockify API key. Used by every tool call.
CLOCKIFY_API_KEY=your-api-key

# Optional: workspace auto-detection is sufficient for single-account
# users. Set explicitly if you belong to more than one workspace.
# CLOCKIFY_WORKSPACE_ID=

# Optional: IANA timezone for relative-time parsing (e.g. "today").
# CLOCKIFY_TIMEZONE=Europe/Belgrade

# Optional: human-readable text logs to stderr.
# MCP_LOG_FORMAT=text
# MCP_LOG_LEVEL=info
