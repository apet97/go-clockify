# clockify-mcp: Shared Service Production Preset
# -----------------------------------------------------------------------------
# For multi-tenant or shared-service deployments behind a reverse proxy.
# Use Postgres for the control plane and OIDC for authentication.
#
# Apply this preset by exporting MCP_PROFILE=shared-service (or
# --profile=shared-service). The profile pins the strict-gate flags
# below as defaults; explicit values in this env file still win.

MCP_PROFILE=shared-service

# REQUIRED: Your Clockify API Key (or use per-tenant keys in the database)
CLOCKIFY_API_KEY=your-api-key

# Control Plane: Postgres is mandatory for HA/multi-process.
# Do not use 'memory' or 'file' backends in production (single process only).
MCP_CONTROL_PLANE_DSN=postgres://user:pass@db-host:5432/clockify_mcp?sslmode=verify-full

# Auth: OIDC with JWT verification.
MCP_OIDC_ISSUER=https://auth.example.com/
MCP_OIDC_AUDIENCE=clockify-mcp-shared
# MCP_RESOURCE_URI=https://mcp.example.com  # optional RFC 8707 resource indicator

# Hosted-service strict gates (pinned by the profile; uncomment to
# override). Each of these is a hard requirement for any deployment
# accepting tokens from outside your trust boundary — flipping them
# off without a documented reason is the canonical "shared service
# accidentally accepts any-issuer token" footgun.
# MCP_OIDC_STRICT=1            # require audience or resource binding; reject tokens missing exp
# MCP_REQUIRE_TENANT_CLAIM=1   # reject tokens with empty tenant claim (no fallback to default tenant)
# MCP_DISABLE_INLINE_SECRETS=1 # reject credential refs with backend=inline

# Listeners
MCP_HTTP_BIND=:8080
MCP_METRICS_BIND=:9091
MCP_HTTP_INLINE_METRICS_ENABLED=false

# Policy: time_tracking_safe is the recommended AI-facing default
# (entries + tags on entries; no workspace-level project/client/task
# create writes). safe_core is acceptable for trusted-team
# deployments that need broader writes.
# CLOCKIFY_POLICY=time_tracking_safe   # profile default; uncomment to override

# Logging: Structured JSON for production log aggregators
MCP_LOG_FORMAT=json
