# clockify-mcp: Shared Service Production Preset
# -----------------------------------------------------------------------------
# For multi-tenant or shared-service deployments behind a reverse proxy.
# Use Postgres for the control plane and OIDC for authentication.

# REQUIRED: Your Clockify API Key (or use per-tenant keys in the database)
CLOCKIFY_API_KEY=your-api-key

# Transport: Spec-strict streamable HTTP (MCP 2025-03-26+)
MCP_TRANSPORT=streamable_http

# Control Plane: Postgres is mandatory for HA/multi-process.
# Do not use 'memory' or 'file' backends in production (single process only).
MCP_CONTROL_PLANE_DSN=postgres://user:pass@db-host:5432/clockify_mcp?sslmode=verify-full

# Auth: OIDC with JWT verification.
MCP_AUTH_MODE=oidc
MCP_OIDC_ISSUER=https://auth.example.com/
MCP_OIDC_AUDIENCE=clockify-mcp-shared

# Listeners
MCP_HTTP_BIND=:8080
MCP_METRICS_BIND=:9091
MCP_HTTP_INLINE_METRICS_ENABLED=false

# Audit: Abort tool calls if audit persistence fails (fail-closed)
MCP_AUDIT_DURABILITY=fail_closed

# Policy: Restricted to safe day-to-day operations
CLOCKIFY_POLICY=safe_core

# Logging: Structured JSON for production log aggregators
MCP_LOG_FORMAT=json
