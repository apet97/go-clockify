# clockify-mcp: Self-Hosted Production Preset
# -----------------------------------------------------------------------------
# For single-user or small-team deployments. Usually runs as a local 
# background process or a simple container.

# REQUIRED: Your Clockify API Key
CLOCKIFY_API_KEY=your-api-key

# Transport: Standard stdio (for local IDEs/CLI) or HTTP
MCP_TRANSPORT=stdio

# Control Plane: File backend is acceptable for single-process persistence.
# 'memory' is safe but loses session/audit data on restart.
MCP_CONTROL_PLANE_DSN=file:///var/lib/clockify-mcp/state.json

# Auth: For HTTP transport, use a strong static bearer token.
# MCP_AUTH_MODE=static_bearer
# MCP_BEARER_TOKEN=your-strong-random-token-here

# Policy: Standard allows most operations but blocks admin-level tools.
CLOCKIFY_POLICY=standard

# Audit: Best effort is sufficient for most self-hosted scenarios.
MCP_AUDIT_DURABILITY=best_effort

# Logging: Human-readable text
MCP_LOG_FORMAT=text
