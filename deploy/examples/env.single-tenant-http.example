# clockify-mcp: single-tenant-http profile
# -----------------------------------------------------------------------------
# Single-tenant streamable HTTP deployment: one process, one Clockify
# workspace, one bearer token. Sessions live in the file-backed
# control plane; MCP_ALLOW_DEV_BACKEND=1 is set explicitly by the
# profile because the file store is safe only when exactly one
# process is reading/writing it.
#
# Apply via:
#   source env.single-tenant-http.example && clockify-mcp
# Or equivalently:
#   clockify-mcp --profile=single-tenant-http
#
# See docs/deploy/profile-single-tenant-http.md for the profile rationale.

MCP_PROFILE=single-tenant-http

# REQUIRED: Your Clockify API key. Used by every tool call.
CLOCKIFY_API_KEY=your-api-key

# REQUIRED: Strong static bearer token (>=16 chars). Callers present
# it as Authorization: Bearer <token>. Rotate by editing this file
# and restarting the process.
MCP_BEARER_TOKEN=replace-with-a-strong-random-token-at-least-16-characters

# Optional: override the default bind. The profile leaves MCP_HTTP_BIND
# at :8080 when unset.
# MCP_HTTP_BIND=:8080

# Optional: override the file-backed control plane path. The profile
# default is /var/lib/clockify-mcp/cp.json — ensure the user running
# clockify-mcp can write to the parent directory.
# MCP_CONTROL_PLANE_DSN=file:///var/lib/clockify-mcp/cp.json

# Optional: pin a dedicated metrics listener. Recommended so /metrics
# is not inline on the main HTTP listener.
# MCP_METRICS_BIND=:9091
# MCP_METRICS_BEARER_TOKEN=replace-with-a-distinct-metrics-token
