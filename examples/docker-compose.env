# Docker Compose environment file
# Copy to .env and fill in your values:
#   cp examples/docker-compose.env deploy/.env

# Required
CLOCKIFY_API_KEY=your-clockify-api-key
MCP_BEARER_TOKEN=your-secret-bearer-token

# Optional
# CLOCKIFY_WORKSPACE_ID=
# CLOCKIFY_TIMEZONE=UTC
# CLOCKIFY_POLICY=standard
# MCP_ALLOWED_ORIGINS=https://your-app.example.com
# MCP_LOG_FORMAT=json
# MCP_LOG_LEVEL=info
# VERSION=v0.3.0
