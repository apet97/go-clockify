# =============================================================================
# Clockify MCP Server (Go) — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# --- Core (Required) ---------------------------------------------------------

# Your Clockify API key (get from https://app.clockify.me/user/preferences#advanced)
CLOCKIFY_API_KEY=

# Workspace ID (auto-detected if your API key has access to only one workspace)
# CLOCKIFY_WORKSPACE_ID=

# --- API Configuration -------------------------------------------------------

# CLOCKIFY_BASE_URL=https://api.clockify.me/api/v1
# CLOCKIFY_REPORTS_URL=
# CLOCKIFY_TIMEZONE=UTC
# CLOCKIFY_INSECURE=0

# --- Safety & Control --------------------------------------------------------

# Policy mode: read_only, safe_core, standard (default), full
# CLOCKIFY_POLICY=standard

# Comma-separated tool names to block
# CLOCKIFY_DENY_TOOLS=

# Comma-separated Tier 2 domain groups to block
# CLOCKIFY_DENY_GROUPS=

# Comma-separated allowed Tier 2 groups (overrides mode default)
# CLOCKIFY_ALLOW_GROUPS=

# Dry-run for destructive tools: enabled (default), off
# CLOCKIFY_DRY_RUN=enabled

# Duplicate entry detection: warn (default), block, off
# CLOCKIFY_DEDUPE_MODE=warn

# Recent entries to check for duplicates (default 25)
# CLOCKIFY_DEDUPE_LOOKBACK=25

# Overlapping entry detection: true (default), off
# CLOCKIFY_OVERLAP_CHECK=true

# --- Bootstrap ---------------------------------------------------------------

# Tool visibility: full_tier1 (default), minimal, custom
# CLOCKIFY_BOOTSTRAP_MODE=full_tier1

# Tool list for custom mode (comma-separated)
# CLOCKIFY_BOOTSTRAP_TOOLS=

# --- Performance -------------------------------------------------------------

# Max concurrent tool calls (default 10, 0 disables)
# CLOCKIFY_MAX_CONCURRENT=10

# Max tool calls per 60s window (default 120, 0 disables)
# CLOCKIFY_RATE_LIMIT=120

# Token truncation budget (default 8000, 0 disables)
# CLOCKIFY_TOKEN_BUDGET=8000

# --- Transport ---------------------------------------------------------------

# Transport mode: stdio (default) or http
# MCP_TRANSPORT=stdio

# HTTP listen address (default :8080)
# MCP_HTTP_BIND=:8080

# Bearer token (required for HTTP mode)
# MCP_BEARER_TOKEN=

# Comma-separated allowed CORS origins (cross-origin rejected if unset)
# MCP_ALLOWED_ORIGINS=

# Set to 1 to allow all origins (not recommended for production)
# MCP_ALLOW_ANY_ORIGIN=0

# Max request body size in bytes (default 2MB)
# MCP_HTTP_MAX_BODY=2097152

# Log format: text (default) or json
# MCP_LOG_FORMAT=text

# Log level: debug, info (default), warn, error
# MCP_LOG_LEVEL=info
